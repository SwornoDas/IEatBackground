{
    "manifest_version": 3,
    "name": "IEatBackground",
    "version": "1.0",
    "description": "Add a custom background to your google home page.",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "action": {
        "default_title": "My Extension",
        "default_icon": "images/icon48.png"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "css": [
                "main.css"
            ]
        }
    ],
    "icons": {
        "16": "images/icon48.png",
        "48": "images/icon48.png",
        "128": "images/icon48.png"
    }
}